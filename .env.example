# FoundNest mobile app — copy to .env for local overrides (optional)
#
# DO NOT put GEMINI_API_KEY here. The app sends photos to your backend;
# Gemini runs only on the server (Render env vars).
#
# EXPO_PUBLIC_* variables are bundled into the app and can be scraped from APKs.

# Optional: override API base URL
# EXPO_PUBLIC_API_URL=https://foundnest-backend.onrender.com
